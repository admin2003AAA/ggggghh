# =============================================
# Telegram Bot Configuration
# =============================================

# Your Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Comma-separated list of allowed Telegram user IDs (leave empty to allow all)
# Example: ALLOWED_USERS=123456789,987654321
ALLOWED_USERS=

# =============================================
# Indexing Configuration
# =============================================

# Path to the data directory to index (relative or absolute)
DATA_DIR=./data

# Path to the SQLite index database
INDEX_DB_PATH=./index.db

# Maximum file size to index in MB (files larger than this are skipped)
MAX_FILE_SIZE_MB=50

# =============================================
# Bot Settings
# =============================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Maximum number of search results to return
MAX_SEARCH_RESULTS=10
